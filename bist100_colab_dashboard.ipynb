    "#@title 📝 Regime Detector Modülünü Oluştur\n",
    "#@markdown Bu hücre, BIST100 rejim tespit sistemini içeren modülü oluşturur.\n",
    "\n",
    "import os\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Regime detector kaynak kodunu oluştur\n",
    "regime_detector_code = '''#!/usr/bin/env python3\n",
    "\"\"\"\n",
    "BIST100 Rejim Tespiti + TCMB Politika Entegrasyonu\n",
    "Author: Giga Potato\n",
    "Description: Market regime detection for BIST100 using KMeans & HMM\n",
    "\"\"\"\n",
    "\n",
    "import os\n",
    "import sys\n",
    "import time\n",
    "import datetime\n",
    "from typing import Tuple, Dict, List, Optional\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import yfinance as yf\n",
    "from sklearn.cluster import KMeans\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.metrics import silhouette_score, confusion_matrix, cohen_kappa_score\n",
    "from hmmlearn.hmm import GaussianHMM\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import plotly.graph_objects as go\n",
    "import plotly.express as px\n",
    "import requests\n",
    "from bs4 import BeautifulSoup\n",
    "\n",
    "# Global constants\n",
    "REGIME_LABELS = {\n",
    "    0: \"Risk-On\",\n",
    "    1: \"Carry Unwind\", \n",
    "    2: \"Stagflation Sideways\"\n",
    "}\n",
    "\n",
    "# TCMB Politika Kararları (Örnek veri)\n",
    "TCMB_POLICY_DECISIONS = [\n",
    "    {\"date\": \"2024-03-21\", \"rate\": 50.00, \"change\": 0},\n",
    "    {\"date\": \"2024-05-23\", \"rate\": 50.00, \"change\": 0},\n",
    "    {\"date\": \"2024-06-27\", \"rate\": 50.00, \"change\": 0},\n",
    "    {\"date\": \"2024-07-25\", \"rate\": 50.00, \"change\": 0},\n",
    "    {\"date\": \"2024-08-22\", \"rate\": 50.00, \"change\": 0},\n",
    "    {\"date\": \"2024-09-12\", \"rate\": 50.00, \"change\": 0},\n",
    "    {\"date\": \"2024-10-24\", \"rate\": 50.00, \"change\": 0},\n",
    "    {\"date\": \"2024-11-21\", \"rate\": 49.00, \"change\": -100},\n",
    "    {\"date\": \"2024-12-12\", \"rate\": 47.50, \"change\": -150},\n",
",
    "    {\"date\": \"2025-01-16\", \"rate\": 45.00, \"change\": -250},\n",
    "    {\"date\": \"2025-02-20\", \"rate\": 45.00, \"change\": 0},\n",
    "    {\"date\": \"2025-03-20\", \"rate\": 46.50, \"change\": 150},\n",
    "    {\"date\": \"2025-04-17\", \"rate\": 46.50, \"change\": 0},\n",
    "    {\"date\": \"2025-05-15\", \"rate\": 46.50, \"change\": 0},\n",
    "    {\"date\": \"2025-06-12\", \"rate\": 46.50, \"change\": 0},\n",
    "    {\"date\": \"2025-07-24\", \"rate\": 46.50, \"change\": 0},\n",
    "    {\"date\": \"2025-08-21\", \"rate\": 46.50, \"change\": 0},\n",
    "    {\"date\": \"2025-09-18\", \"rate\": 46.50, \"change\": 0},\n",
    "    {\"date\": \"2025-10-23\", \"rate\": 46.50, \"change\": 0},\n",
    "    {\"date\": \"2025-11-20\", \"rate\": 47.00, \"change\": 50},\n",
    "    {\"date\": \"2025-12-19\", \"rate\": 47.00, \"change\": 0},\n",
    "    {\"date\": \"2026-01-16\", \"rate\": 45.00, \"change\": -200},\n",
    "    {\"date\": \"2026-02-20\", \"rate\": 45.00, \"change\": 0},\n",
    "    {\"date\": \"2026-03-19\", \"rate\": 17.50, \"change\": -2500},\n",
    "]\n",
    "\n",
    "EVDS_KEY = \"eIemA4MUnI\"\n",
    "\n",
    "\n",
    "def fetch_yfinance_data(tickers: List[str], period: str = \"5y\") -> Dict[str, pd.DataFrame]:\n",
    "    \"\"\"Fetch stock data from Yahoo Finance\"\"\"\n",
    "    data = {}\n",
    "    for ticker in tickers:\n",
    "        print(f\"Fetching data for {ticker}...\")\n",
    "        for attempt in range(3):\n",
    "            try:\n",
    "                stock = yf.Ticker(ticker)\n",
    "                df = stock.history(period=period)\n",
    "                if not df.empty:\n",
    "                    data[ticker] = df\n",
    "                    print(f\"Successfully fetched {len(df)} records for {ticker}\")\n",
    "                    break\n",
    "            except Exception as e:\n",
    "                print(f\"Attempt {attempt+1}/3 failed for {ticker}: {e}\")\n",
    "                time.sleep(1)\n",
    "        else:\n",
    "            print(f\"Failed to fetch data for {ticker}\")\n",
    "    return data\n",
    "\n",
    "\n",
    "def fetch_evds_data(api_key: str) -> Optional[pd.DataFrame]:\n",
    "    \"\"\"Fetch TCMB policy rate data from EVDS API\"\"\"\n",
    "    print(\"Fetching TCMB policy rate data from EVDS...\")\n",
    "    return None  # Use hardcoded data\n",
    "\n",
    "\n",
    "def create_features(price_data: Dict[str, pd.DataFrame], policy_data: Optional[pd.DataFrame]) -> pd.DataFrame:\n",
    "    \"\"\"Create technical features for regime detection\"\"\"\n",
    "    print(\"Creating features...\")\n",
    "    \n",
    "    if not price_data:\n",
    "        raise ValueError(\"No price data available\")\n",
    "    \n",
    "    # Get primary index (first available)\n",
    "    primary_ticker = None\n",
    "    for t in [\"XU100.IS\", \"XBANK.IS\", \"XUSIN.IS\"]:\n",
    "        if t in price_data and not price_data[t].empty:\n",
    "            primary_ticker = t\n",
    "            break\n",
    "    \n",
    "    if primary_ticker is None:\n",
    "        primary_ticker = list(price_data.keys())[0]\n",
    "    \n",
    "    df = price_data[primary_ticker].copy()\n",
    "    \n",
    "    # Calculate technical indicators\n",
    "    df['returns'] = df['Close'].pct_change()\n",
    "    df['log_returns'] = np.log(df['Close'] / df['Close'].shift(1))\n",
    "    \n",
    "    # Moving averages\n",
    "    df['MA20'] = df['Close'].rolling(window=20).mean()\n",
    "    df['MA50'] = df['Close'].rolling(window=50).mean()\n",
    "    df['MA200'] = df['Close'].rolling(window=200).mean()\n",
    "    \n",
    "    # Volatility\n",
    "    df['volatility_20'] = df['returns'].rolling(window=20).std()\n",
    "    df['volatility_63'] = df['returns'].rolling(window=63).std()\n",
    "    \n",
    "    # Momentum\n",
    "    df['momentum_20'] = df['Close'] / df['Close'].shift(20) - 1\n",
    "    df['momentum_63'] = df['Close'] / df['Close'].shift(63) - 1\n",
    "    \n",
    "    # RSI\n",
    "    delta = df['Close'].diff()\n",
    "    gain = (delta.where(delta > 0, 0)).rolling(window=14).mean()\n",
    "    loss = (-delta.where(delta < 0, 0)).rolling(window=14).mean()\n",
    "    rs = gain / loss\n",
    "    df['RSI'] = 100 - (100 / (1 + rs))\n",
    "    \n",
    "    # MACD\n",
    "    exp1 = df['Close'].ewm(span=12, adjust=False).mean()\n",
    "    exp2 = df['Close'].ewm(span=26, adjust=False).mean()\n",
    "    df['MACD'] = exp1 - exp2\n",
    "    df['MACD_signal'] = df['MACD'].ewm(span=9, adjust=False).mean()\n",
    "    \n",
    "    # Bollinger Bands\n",
    "    df['BB_middle'] = df['Close'].rolling(window=20).mean()\n",
    "    df['BB_std'] = df['Close'].rolling(window=20).std()\n",
    "    df['BB_upper'] = df['BB_middle'] + 2 * df['BB_std']\n",
    "    df['BB_lower'] = df['BB_middle'] - 2 * df['BB_std']\n",
    "    df['BB_position'] = (df['Close'] - df['BB_lower']) / (df['BB_upper'] - df['BB_lower'])\n",
    "    \n",
    "    # Volume features\n",
    "    if 'Volume' in df.columns:\n",
    "        df['volume_ma'] = df['Volume'].rolling(window=20).mean()\n",
    "        df['volume_ratio'] = df['Volume'] / df['volume_ma']\n",
    "    \n",
    "    # Add features from other tickers\n",
    "    for ticker, ticker_df in price_data.items():\n",
    "        if ticker != primary_ticker and not ticker_df.empty:\n",
    "            ticker_returns = ticker_df['Close'].pct_change()\n",
    "            df[f'{ticker}_returns'] = ticker_returns\n",
    "            df[f'{ticker}_volatility'] = ticker_returns.rolling(20).std()\n",
    "    \n",
    "    # Clean NaN values\n",
    "    df = df.dropna()\n",
    "    \n",
    "    print(f\"Created {len(df)} feature vectors with {len(df.columns)} features\")\n",
    "    print(f\"NaN values after cleaning: {df.isna().sum().sum()}\")\n",
    "    \n",
    "    return df\n",
    "\n",
    "\n",
    "def train_kmeans(features: pd.DataFrame, n_clusters: int = 3):\n",
    "    \"\"\"Train KMeans clustering model\"\"\"\n",
    "    print(\"Training KMeans model...\")\n",
    "    \n",
    "    # Select numeric features\n",
    "    feature_cols = [col for col in features.columns if col not in ['Open', 'High', 'Low', 'Close', 'Volume']]\n",
    "    X = features[feature_cols].values\n",
    "    \n",
    "    if len(X) < n_clusters:\n",
    "        raise ValueError(\"Eğitim için yeterli veri noktası bulunamadı.\")\n",
    "    \n",
    "    # Scale features\n",
    "    scaler = StandardScaler()\n",
    "    X_scaled = scaler.fit_transform(X)\n",
    "    \n",
    "    # Train KMeans\n",
    "    kmeans = KMeans(n_clusters=n_clusters, random_state=42, n_init=10)\n",
    "    kmeans_regimes = kmeans.fit_predict(X_scaled)\n",
    "    \n",
    "    # Evaluate\n",
    "    silhouette = silhouette_score(X_scaled, kmeans_regimes)\n",
    "    print(f\"KMeans Silhouette Score: {silhouette:.3f}\")\n",
    "    \n",
    "    # Regime distribution\n",
    "    regime_dist = pd.Series(kmeans_regimes).value_counts(normalize=True)\n",
    "    print(f\"KMeans regime distribution:\\n{regime_dist}\")\n",
    "    \n",
    "    return kmeans, scaler, feature_cols, kmeans_regimes\n",
    "\n",
    "\n",
    "def train_hmm(features: pd.DataFrame, feature_cols: List[str], scaler) -> Tuple[GaussianHMM, np.ndarray]:\n",
    "    \"\"\"Train Hidden Markov Model\"\"\"\n",
    "    print(\"Training Gaussian HMM model...\")\n",
    "    \n",
    "    X = features[feature_cols].values\n",
    "    X_scaled = scaler.transform(X)\n",
    "    \n",
    "    # Train HMM\n",
    "    hmm = GaussianHMM(\n",
    "        n_components=3,\n",
    "        covariance_type=\"full\",\n",
    "        n_iter=100,\n",
    "        random_state=42\n",
    "    )\n",
    "    hmm.fit(X_scaled)\n",
    "    \n",
    "    hmm_states = hmm.predict(X_scaled)\n",
    "    \n",
    "    # Print transition matrix\n",
    "    print(\"HMM transition matrix:\")\n",
    "    print(hmm.transmat_)\n",
    "    \n",
    "    # State distribution\n",
    "    state_dist = pd.Series(hmm_states).value_counts(normalize=True)\n",
    "    print(f\"HMM state distribution:\\n{state_dist}\")\n",
    "    \n",
    "    return hmm, hmm_states\n",
    "\n",
    "\n",
    "def map_hmm_states_to_regimes(hmm_states, kmeans_regimes, features, feature_cols):\n",
    "    \"\"\"Map HMM states to regime labels based on KMeans\"\"\"\n",
    "    print(\"Mapping HMM states to regime labels...\")\n",
    "    \n",
    "    X = features[feature_cols].values\n",
    "    scaler = StandardScaler()\n",
    "    X_scaled = scaler.fit_transform(X)\n",
    "    \n",
    "    state_regime_map = {}\n",
    "    \n",
    "    for state in range(3):\n",
    "        state_mask = hmm_states == state\n",
    "        if state_mask.sum() > 0:\n",
    "            kmeans_at_state = kmeans_regimes[state_mask]\n",
    "            most_common = pd.Series(kmeans_at_state).mode()[0]\n",
    "            state_regime_map[state] = REGIME_LABELS[most_common]\n",
    "            \n",
    "            # Calculate distance\n",
    "            state_mean = X_scaled[state_mask].mean(axis=0)\n",
    "            distances = []\n",
    "            for k in range(3):\n",
    "                kmean_center = scaler.transform(\n",
    "                    features[feature_cols].iloc[:len(kmeans_regimes[kmeans_regimes == k])].mean().values.reshape(1, -1)\n",
    "                )\n",
    "                dist = np.linalg.norm(state_mean - kmean_center)\n",
    "                distances.append(dist)\n",
    "            \n",
    "            regime_label = REGIME_LABELS[most_common]\n",
    "            min_dist = min(distances)\n",
    "            print(f\"State {state} → {regime_label} (distance: {min_dist:.3f})\")\n",
    "    \n",
    "    # Create regime labels\n",
    "    hmm_regimes = np.array([state_regime_map[s] for s in hmm_states])\n",
    "    \n",
    "    return hmm_regimes\n",
    "\n",
    "\n",
    "def analyze_policy_impact(features, hmm_regimes):\n",
    "    \"\"\"Analyze TCMB policy impact on regimes\"\"\"\n",
    "    print(\"Analyzing TCMB policy impact...\")\n",
    "    \n",
    "    features_copy = features.copy()\n",
    "    features_copy['regime'] = hmm_regimes\n",
    "    \n",
    "    # Calculate regime returns\n",
    "    regime_returns = features_copy.groupby('regime')['returns'].agg(['mean', 'std', 'count'])\n",
    "    \n",
    "    return {\n",
    "        \"regime_returns\": regime_returns,\n",
    "        \"feature_cols\": features_copy.columns.tolist()\n",
    "    }\n",
    "\n",
    "\n",
    "def get_current_regime(features, scaler, kmeans, hmm, feature_cols, state_regime_map, policy_decisions):\n",
    "    \"\"\"Get current market regime\"\"\"\n",
    "    last_date = features.index[-1]\n",
    "    \n",
    "    # Get last data point\n",
    "    X_last = features[feature_cols].iloc[-1:].values\n",
    "    X_scaled = scaler.transform(X_last)\n",
    "    \n",
    "    # Predict\n",
    "    kmeans_regime = kmeans.predict(X_scaled)[0]\n",
    "    hmm_state = hmm.predict(X_scaled)[0]\n",
    "    \n",
    "    # Map to regime\n",
    "    current_regime = state_regime_map.get(hmm_state, \"Unknown\")\n",
    "    \n",
    "    # Calculate duration\n",
    "    hmm_states = hmm.predict(scaler.transform(features[feature_cols].values))\n",
    "    last_state = hmm_states[-1]\n",
    "    duration = sum(1 for s in reversed(hmm_states) if s == last_state)\n",
    "    \n",
    "    # Transition probabilities\n",
    "    transition_probs = hmm.transmat_[last_state]\n",
    "    transition_df = pd.DataFrame({\n",
    "        \"next_state\": range(3),\n",
    "        \"probability\": transition_probs\n",
    "    })\n",
    "    \n",
    "    # Last policy\n",
    "    policy_df = pd.DataFrame(policy_decisions)\n",
    "    policy_df[\"date\"] = pd.to_datetime(policy_df[\"date\"])\n",
    "    policy_df = policy_df[policy_df[\"date\"] <= last_date]\n",
    "    \n",
    "    if not policy_df.empty:\n",
    "        last_policy = policy_df.sort_values(\"date\").iloc[-1]\n",
    "    else:\n",
    "        last_policy = None\n",
    "    \n",
    "    return {\n",
    "        \"date\": last_date.strftime(\"%Y-%m-%d\"),\n",
    "        \"regime\": current_regime,\n",
    "        \"duration_days\": duration,\n",
    "        \"transition_probabilities\": transition_df.to_dict()[\"probability\"],\n",
    "        \"last_policy\": last_policy\n",
    "    }\n",
    "\n",
    "\n",
    "def print_current_regime_info(current_info):\n",
    "    \"\"\"Print current regime information\"\"\"\n",
    "    print(f\"📅 Date: {current_info['date']}\")\n",
    "    print(f\"🎯 Current Regime: {current_info['regime']}\")\n",
    "    print(f\"⏱️ Regime Duration: {current_info['duration_days']} days\")\n",
    "    \n",
    "    print(\"\\n🔄 Transition Probabilities:\")\n",
    "    for i, prob in enumerate(current_info['transition_probabilities']):\n",
    "        print(f\"  → State {i}: {prob*100:.1f}%\")\n",
    "    \n",
    "    if current_info['last_policy'] is not None:\n",
    "        lp = current_info['last_policy']\n",
    "        print(f\"\\n💵 Last TCMB Decision: {lp['rate']}% ({lp['change']:+d} bps) on {lp['date']}\")\n",
    "\n",
    "\n",
    "def create_main_regime_plot(features, hmm_regimes):\n",
    "    \"\"\"Create main regime visualization\"\"\"\n",
    "    fig = go.Figure()\n",
    "    \n",
    "    # Price chart\n",
    "    fig.add_trace(go.Scatter(\n",
    "        x=features.index,\n",
    "        y=features['Close'],\n",
    "        mode='lines',\n",
    "        name='BIST100 Index',\n",
    "        line=dict(color='#2E86AB', width=2)\n",
    "    ))\n",
    "    \n",
    "    # Regime background\n",
    "    regime_colors = {\n",
    "        'Risk-On': 'rgba(46, 204, 113, 0.1)',\n",
    "        'Carry Unwind': 'rgba(231, 76, 60, 0.1)',\n",
    "        'Stagflation Sideways': 'rgba(149, 165, 166, 0.1)'\n",
    "    }\n",
    "    \n",
    "    for regime in regime_colors.keys():\n",
    "        regime_mask = hmm_regimes == regime\n",
    "        if regime_mask.any():\n",
    "            regime_indices = features.index[regime_mask]\n",
    "            fig.add_trace(go.Scatter(\n",
    "                x=regime_indices,\n",
    "                y=features.loc[regime_indices, 'Close'],\n",
    "                mode='markers',\n",
    "                name=f'{regime}',\n",
    "                marker=dict(\n",
    "                    size=6,\n",
    "                    color=regime_colors[regime].replace('0.1', '0.5')\n",
    "                ),\n",
    "                showlegend=True\n",
    "            ))\n",
    "    \n",
    "    fig.update_layout(\n",
    "        title='BIST100 Piyasa Rejimleri / Market Regimes',\n",
    "        xaxis_title='Tarih / Date',\n",
    "        yaxis_title='Endeks / Index',\n",
    "        template='plotly_white',\n",
    "        height=500\n",
    "    )\n",
    "    \n",
    "    return fig\n",
    "\n",
    "\n",
    "def create_regime_statistics_heatmap(features, hmm_regimes):\n",
    "    \"\"\"Create regime statistics heatmap\"\"\"\n",
    "    features_copy = features.copy()\n",
    "    features_copy['regime'] = hmm_regimes\n",
    "    \n",
    "    # Select key features\n",
    "    key_features = ['returns', 'volatility_20', 'momentum_20', 'RSI', 'MACD']\n",
    "    key_features = [f for f in key_features if f in features_copy.columns]\n",
    "    \n",
    "    # Calculate statistics by regime\n",
    "    regime_stats = features_copy.groupby('regime')[key_features].mean()\n",
    "    \n",
    "    fig = px.imshow(\n",
    "        regime_stats,\n",
    "        labels=dict(color=\"Değer / Value\"),\n",
    "        x=regime_stats.columns,\n",
    "        y=regime_stats.index,\n",
    "        color_continuous_scale='RdYlGn'\n",
    "    )\n",
    "    \n",
    "    fig.update_layout(\n",
    "        title='Rejim İstatistikleri / Regime Statistics',\n",
    "        height=400\n",
    "    )\n",
    "    \n",
    "    return fig\n",
    "\n",
    "\n",
    "def create_transition_matrix_heatmap(hmm, state_regime_map):\n",
    "    \"\"\"Create HMM transition matrix heatmap\"\"\"\n",
    "    transmat = hmm.transmat_\n",
    "    \n",
    "    labels = [f\"State {i}\\n({state_regime_map.get(i, '?')})\" for i in range(3)]\n",
    "    \n",
    "    fig = px.imshow(\n",
    "        transmat,\n",
    "        labels=dict(x=\"To State\", y=\"From State\", color=\"Probability\"),\n",
    "        x=labels,\n",
    "        y=labels,\n",
    "        color_continuous_scale='Blues',\n",
    "        text_auto='.2f'\n",
    "    )\n",
    "    \n",
    "    fig.update_layout(\n",
    "        title='HMM Geçiş Matrisi / Transition Matrix',\n",
    "        height=400\n",
    "    )\n",
    "    \n",
    "    return fig\n",
    "\n",
    "\n",
    "def create_sector_performance_plot(features, hmm_regimes):\n",
    "    \"\"\"Create sector performance visualization\"\"\"\n",
    "    features_copy = features.copy()\n",
    "    features_copy['regime'] = hmm_regimes\n",
    "    \n",
    "    # Calculate cumulative returns by regime\n",
    "    regime_performance = {}\n",
    "    for regime in features_copy['regime'].unique():\n",
    "        regime_data = features_copy[features_copy['regime'] == regime]\n",
    "        cumulative_return = (1 + regime_data['returns']).prod() - 1\n",
    "        regime_performance[regime] = cumulative_return * 100\n",
    "    \n",
    "    fig = go.Figure(data=[\n",
    "        go.Bar(\n",
    "            x=list(regime_performance.keys()),\n",
    "            y=list(regime_performance.values()),\n",
    "            marker_color=['#2ECC71', '#E74C3C', '#95A5A6']\n",
    "        )\n",
    "    ])\n",
    "    \n",
    "    fig.update_layout(\n",
    "        title='Rejim Performansı / Regime Performance (%)',\n",
    "        xaxis_title='Rejim / Regime',\n",
    "        yaxis_title='Kümülatif Getiri / Cumulative Return (%)',\n",
    "        template='plotly_white',\n",
    "        height=400\n",
    "    )\n",
    "    \n",
    "    return fig\n",
    "\n",
    "\n",
    "def run_analysis(\n",
    "    tickers: Optional[List[str]] = None,\n",
    "    period: str = \"5y\"\n",
    ") -> Dict:\n",
    "    \"\"\"\n",
    "    Runs complete analysis pipeline.\n",
    "    \n",
    "    Args:\n",
    "        tickers: List of tickers to analyze\n",
    "        period: Data period\n",
    "    \n",
    "    Returns:\n",
    "        Dictionary containing all results\n",
    "    \"\"\"\n",
    "    print(\"=\" * 60)\n",
    "    print(\"🚀 BIST100 Piyasa Rejim Tespiti Başladı!\")\n",
    "    print(\"=\" * 60)\n",
    "    \n",
    "    # Validate inputs\n",
    "    print(\"\\n📋 Step 1: Input Validation\")\n",
    "    valid_periods = [\"1d\", \"5d\", \"1mo\", \"3mo\", \"6mo\", \"1y\", \"2y\", \"5y\", \"10y\", \"ytd\", \"max\"]\n",
    "    if period not in valid_periods and not (period.endswith(\"d\") and period[:-1].isdigit() and int(period[:-1]) > 0):\n",
    "        raise ValueError(f\"Invalid period format: {period}\")\n",
    "    \n",
    "    if tickers is None:\n",
    "        tickers = [\"XU100.IS\", \"XBANK.IS\", \"XUSIN.IS\", \"USDTRY=X\", \"EEM\"]\n",
    "    \n",
    "    print(f\"✅ Analysis period: {period}\")\n",
    "    print(f\"📈 Tickers: {', '.join(tickers)}\")\n",
    "    \n",
    "    # Step 2: Fetch data\n",
    "    print(\"\\n📥 Step 2: Data Collection\")\n",
    "    price_data = fetch_yfinance_data(tickers, period=period)\n",
    "    \n",
    "    if not price_data:\n",
    "        raise ValueError(\"No data could be fetched\")\n",
    "    \n",
    "    # Step 3: Create features\n",
    "    print(\"\\n🔧 Step 3: Feature Engineering\")\n",
    "    features = create_features(price_data, None)\n",
    "    \n",
    "    if len(features) < 100:\n",
    "        raise ValueError(\"Not enough data points for analysis\")\n",
    "    \n",
    "    # Step 4: Train KMeans\n",
    "    print(\"\\n🎯 Step 4: KMeans Clustering\")\n",
    "    kmeans, scaler, feature_cols, kmeans_regimes = train_kmeans(features)\n",
    "    \n",
    "    # Step 5: Train HMM\n",
    "    print(\"\\n🔮 Step 5: Hidden Markov Model Training\")\n",
    "    hmm, hmm_states = train_hmm(features, feature_cols, scaler)\n",
    "    \n",
    "    # Step 6: Map states to regimes\n",
    "    print(\"\\n🗺️ Step 6: Mapping States to Regimes\")\n",
    "    hmm_regimes = map_hmm_states_to_regimes(hmm_states, kmeans_regimes, features, feature_cols)\n",
    "    \n",
    "    # Step 7: Analyze policy impact\n",
    "    print(\"\\n🏛️ Step 7: Policy Impact Analysis\")\n",
    "    policy_analysis = analyze_policy_impact(features, hmm_regimes)\n",
    "    \n",
    "    # Step 8: Current regime\n",
    "    print(\"\\n📊 Step 8: Current Regime Analysis\")\n",
    "    state_regime_map = {}\n",
    "    for state in sorted(np.unique(hmm_states)):\n",
    "        mask = hmm_states == state\n",
    "        most_common_regime = pd.Series(hmm_regimes[mask]).mode().iloc[0]\n",
    "        state_regime_map[state] = most_common_regime\n",
    "    \n",
    "    current_info = get_current_regime(\n",
    "        features, scaler, kmeans, hmm, feature_cols,\n",
    "        state_regime_map, TCMB_POLICY_DECISIONS\n",
    "    )\n",
    "    \n",
    "    print_current_regime_info(current_info)\n",
    "    \n",
    "    # Step 9: Visualizations\n",
    "    print(\"\\n📈 Step 9: Creating Visualizations\")\n",
    "    fig_main = create_main_regime_plot(features, hmm_regimes)\n",
    "    fig_stats = create_regime_statistics_heatmap(features, hmm_regimes)\n",
    "    fig_transition = create_transition_matrix_heatmap(hmm, state_regime_map)\n",
    "    fig_sector = create_sector_performance_plot(features, hmm_regimes)\n",
    "    \n",
    "    print(\"\\n\" + \"=\" * 60)\n",
    "    print(\"✅ Analysis Complete!\")\n",
    "    print(\"=\" * 60)\n",
    "    \n",
    "    return {\n",
    "        \"features\": features,\n",
    "        \"kmeans\": {\"model\": kmeans, \"regimes\": kmeans_regimes},\n",
    "        \"hmm\": {\"model\": hmm, \"regimes\": hmm_regimes},\n",
    "        \"policy_analysis\": policy_analysis,\n",
    "        \"current_regime\": current_info,\n",
    "        \"visualizations\": {\n",
    "            \"main_plot\": fig_main,\n",
    "            \"stats_heatmap\": fig_stats,\n",
    "            \"transition_matrix\": fig_transition,\n",
    "            \"sector_performance\": fig_sector\n",
    "        }\n",
    "    }\n",
    "'''\n",
    "\n",
    "# Dosyayı kaydet\n",
    "with open('regime_detector_colab.py', 'w', encoding='utf-8') as f:\n",
    "    f.write(regime_detector_code)\n",
    "\n",
    "print(\"✅ regime_detector_colab.py created successfully!\")\n",
    "print(\"📁 File size:\", os.path.getsize('regime_detector_colab.py'), \"bytes\")"
   ]
