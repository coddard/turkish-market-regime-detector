    "            plot_bgcolor: 'rgba(0,0,0,0)',\n",
    "            font: { color: '#8892b0' },\n",
    "            margin: { t: 20, r: 20, l: 80, b: 40 },\n",
    "            height: 350\n",
    "        };\n",
    "        \n",
