    "                float((features.loc[hmm_regimes == 'Carry Unwind', 'returns'].mean() or 0) * 100),\n",
    "                float((features.loc[hmm_regimes == 'Stagflation Sideways', 'returns'].mean() or 0) * 100)\n",
    "            ]) + ''',\n",
